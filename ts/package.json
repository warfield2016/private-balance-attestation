{
  "name": "@lp-0005/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for LP-0005 private balance attestation. Wraps the Rust prover (via CLI or WASM) and the off-chain verifier; integrates Logos Messaging for the off-chain path.",
  "license": "(MIT OR Apache-2.0)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./messaging": {
      "types": "./dist/messaging.d.ts",
      "import": "./dist/messaging.mjs",
      "require": "./dist/messaging.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.mjs",
      "require": "./dist/verify.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "@noble/ed25519": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
